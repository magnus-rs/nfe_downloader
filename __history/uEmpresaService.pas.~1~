unit uEmpresaService;

interface

uses
  System.SysUtils, System.JSON, System.Generics.Collections,
  System.IOUtils, uEmpresas, Vcl.Forms;

function CarregarEmpresas: TObjectList<TEmpresa>;
procedure SalvarEmpresas(Lista: TObjectList<TEmpresa>);
procedure AdicionarEmpresa(Empresa: TEmpresa);
procedure RemoverEmpresa(CNPJ: string);
procedure AtualizarEmpresa(Empresa: TEmpresa);

implementation

const
  ARQ = 'empresas.json';

function Caminho: string;
begin
  Result := ExtractFilePath(Application.ExeName) + ARQ;
end;

function CarregarEmpresas: TObjectList<TEmpresa>;
var
  JSON: TJSONObject;
  Arr: TJSONArray;
  Obj: TJSONObject;
  Empresa: TEmpresa;
  I: Integer;
  JSONStr: string;
begin
  Result := TObjectList<TEmpresa>.Create(True);

  if not FileExists(Caminho) then
    Exit;

  JSONStr := TFile.ReadAllText(Caminho);
  JSON := TJSONObject.ParseJSONValue(JSONStr) as TJSONObject;

  try
    Arr := JSON.GetValue<TJSONArray>('empresas');

    if Arr = nil then Exit;

    for I := 0 to Arr.Count - 1 do
    begin
      Obj := Arr.Items[I] as TJSONObject;

      Empresa := TEmpresa.Create;
      Empresa.CNPJ := Obj.GetValue<string>('cnpj');
      Empresa.RazaoSocial := Obj.GetValue<string>('razao_social');
      Empresa.Certificado := Obj.GetValue<string>('certificado');
      Empresa.Senha := Obj.GetValue<string>('senha');
      Result.Add(Empresa);
    end;

  finally
    JSON.Free;
  end;
end;

procedure SalvarEmpresas(Lista: TObjectList<TEmpresa>);
var
  JSON: TJSONObject;
  Arr: TJSONArray;
  Obj: TJSONObject;
  Empresa: TEmpresa;
begin
  JSON := TJSONObject.Create;
  Arr := TJSONArray.Create;

  for Empresa in Lista do
  begin
    Obj := TJSONObject.Create;
    Obj.AddPair('cnpj', Empresa.CNPJ);
    Obj.AddPair('razao_social', Empresa.RazaoSocial);
    Obj.AddPair('certificado', Empresa.Certificado);
    Obj.AddPair('senha', Empresa.Senha);

    Arr.AddElement(Obj);
  end;

  JSON.AddPair('empresas', Arr);

  TFile.WriteAllText(Caminho, JSON.ToString);
end;

procedure AdicionarEmpresa(Empresa: TEmpresa);
var
  Lista: TObjectList<TEmpresa>;
begin
  Lista := CarregarEmpresas;
  try
    Lista.Add(Empresa);
    SalvarEmpresas(Lista);
  finally
    Lista.Free;
  end;
end;

procedure RemoverEmpresa(CNPJ: string);
var
  Lista: TObjectList<TEmpresa>;
  I: Integer;
begin
  Lista := CarregarEmpresas;
  try
    for I := Lista.Count - 1 downto 0 do
      if Lista[I].CNPJ = CNPJ then
        Lista.Delete(I);

    SalvarEmpresas(Lista);
  finally
    Lista.Free;
  end;
end;

procedure AtualizarEmpresa(Empresa: TEmpresa);
var
  Lista: TObjectList<TEmpresa>;
  I: Integer;
begin
  Lista := CarregarEmpresas;
  try
    for I := 0 to Lista.Count - 1 do
    begin
      if Lista[I].CNPJ = Empresa.CNPJ then
      begin
        Lista[I].RazaoSocial := Empresa.RazaoSocial;
        Lista[I].Certificado := Empresa.Certificado;
        Lista[I].Senha := Empresa.Senha;
      end;
    end;

    SalvarEmpresas(Lista);
  finally
    Lista.Free;
  end;
end;

end.
