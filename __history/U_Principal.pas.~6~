unit U_Principal;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.Menus, Vcl.Grids, Vcl.ExtCtrls,
  Vcl.StdCtrls, Vcl.ComCtrls, Vcl.ToolWin, ACBrBase, ACBrDFe, ACBrNFe, ACBrDFeSSL;

type
  TForm_Principal = class(TForm)
    MainMenu1: TMainMenu;
    Arquivo1: TMenuItem;
    Sair1: TMenuItem;
    Sair2: TMenuItem;
    Configuracoes1: TMenuItem;
    Certificados1: TMenuItem;
    ToolBar1: TToolBar;
    StatusBar1: TStatusBar;
    ListBox1: TListBox;
    Splitter1: TSplitter;
    StringGrid1: TStringGrid;
    ACBrNFe1: TACBrNFe;
    procedure FormCreate(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  Form_Principal: TForm_Principal;

implementation

{$R *.dfm}

procedure TForm_Principal.FormCreate(Sender: TObject);
begin
  SetDllDirectory(PChar(ExtractFilePath(Application.ExeName) + 'openssl'));

  ACBrNFe1.Configuracoes.Geral.SSLLib := libOpenSSL;
  ACBrNFe1.Configuracoes.Geral.SSLCryptLib := cryOpenSSL;
  ACBrNFe1.Configuracoes.Geral.SSLHttpLib := httpOpenSSL;
  ACBrNFe1.Configuracoes.Geral.SSLXmlSignLib := xsLibXml2;
  ACBrNFe1.Configuracoes.Arquivos.PathSchemas :=
              ExtractFilePath(Application.ExeName) + 'Schemas\NFe\';

    try
      ACBrNFe1.WebServices.StatusServico.Executar;

      with ACBrNFe1.WebServices.StatusServico do
      begin
        ShowMessage(
          'Status: ' + IntToStr(cStat) + sLineBreak +
          'Motivo: ' + xMotivo
        );
      end;

    except
      on E: Exception do
        ShowMessage('Erro: ' + E.Message);
    end;

end;

end.
